{
  "name": "locallmide",
  "version": "1.0.0",
  "description": "Local LLM-powered code editor — Cursor style",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.cjs",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-rebuild -f -w node-pty",
    "build:dir": "npm run build && electron-builder --dir",
    "build:win": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@octokit/rest": "^20.1.2",
    "chokidar": "^3.6.0",
    "monaco-editor": "^0.52.2",
    "node-llama-cpp": "^3.8.0",
    "node-pty": "^1.0.0",
    "simple-git": "^3.27.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^10.1.0",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^3.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  },
  "build": {
    "appId": "com.locallmide.app",
    "productName": "LocaLLMIDE",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "asar": false,
    "files": [
      "out/**/*",
      "node_modules/**/*",
      "!node_modules/.cache/**/*",
      "!node_modules/electron/**/*",
      "!node_modules/electron-builder/**/*",
      "!node_modules/electron-rebuild/**/*",
      "!node_modules/@electron/rebuild/**/*",
      "!node_modules/electron-vite/**/*",
      "!node_modules/typescript/**/*",
      "!node_modules/vite/**/*",
      "!node_modules/@vitejs/**/*",
      "!node_modules/rollup/**/*",
      "!node_modules/esbuild/**/*",
      "package.json"
    ],
    "npmRebuild": false,
    "extraResources": []
  }
}
